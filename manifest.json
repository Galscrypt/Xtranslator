{
  "manifest_version": 3,
  "name": "X Translator",
  "version": "1.1.1",
  "description": "Мгновенный перевод твитов на русский — axiom.trade, padre.gg",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://axiom.trade/*",
    "https://trade.padre.gg/*",
    "https://translate.googleapis.com/*",
    "https://api.mymemory.translated.net/*",
    "https://api.fxtwitter.com/*",
    "https://cdn.syndication.twimg.com/*",
    "https://mozhi.pussthecat.org/*",
    "https://mozhi.r4fo.com/*",
    "https://mzh.dc09.xyz/*",
    "https://mozhi.adminforge.de/*",
    "https://mozhi.bloat.cat/*",
    "https://mozhi.ducks.party/*",
    "https://simplytranslate.org/*",
    "https://translate.plausibility.cloud/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://trade.padre.gg/*",
        "https://*.padre.gg/*"
      ],
      "js": ["padre/api-interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://axiom.trade/*",
        "https://*.axiom.trade/*"
      ],
      "js": [
        "axiom/constants.js",
        "axiom/utils.js",
        "axiom/cache.js",
        "axiom/diagnostics.js",
        "axiom/translator.js",
        "axiom/observer.js",
        "axiom/ui.js",
        "axiom/content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://trade.padre.gg/*",
        "https://*.padre.gg/*"
      ],
      "js": [
        "padre/constants.js",
        "padre/utils.js",
        "padre/cache.js",
        "padre/diagnostics.js",
        "padre/translator.js",
        "padre/padre-observer.js",
        "padre/ui.js",
        "padre/content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
